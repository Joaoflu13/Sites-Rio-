# Copie para .env e preencha. NÃO commite o .env.

# Postgres POOLED (Supabase porta 6543, com pgbouncer). Usado pelo app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Postgres DIRETO/SESSION (porta 5432). Usado por prisma db push / seed / scripts de ingestão.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres"

# Segredo da sessão (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="troque-por-um-segredo"
AUTH_TRUST_HOST="true"

# URL pública (links de e-mail). Local: http://localhost:3000
APP_URL="http://localhost:3000"

# Admin criado pelo seed (prisma db seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="troque-esta-senha"

# SEU WhatsApp de vendas (só dígitos, com DDD) — aparece na faixa das demos
# ("Quero meu site →"). Sem ele, a faixa aparece sem botão.
SALES_WHATSAPP="21999999999"

# Busca web do enriquecimento (scripts/enrich.ts)
# provider: "serper" (serper.dev, pago/creditos gratis) ou "google-cse" (100 buscas/dia grátis)
FINDER_PROVIDER="serper"
# SERPER_API_KEY="..."
# GOOGLE_CSE_KEY="..."
# GOOGLE_CSE_CX="..."

# E-mail (opcional) — sem isso, e-mails ficam em fallback (logam no console, não enviam)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Sites Rio <contato@seudominio.com>"
